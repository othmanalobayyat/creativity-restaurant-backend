# Copy this file to .env and fill in your values.
# Never commit .env — only .env.example is tracked.

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL / Supabase connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — use a strong random secret in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Cloudinary (required for admin image uploads)
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# CORS: comma-separated allowed origins for production
# Leave empty to allow all in development.
ALLOWED_ORIGINS=https://your-app.com,http://localhost:8081

# Feature flags
# Keep false in production — only enable locally to seed mock data via /api/seed-items
ENABLE_DEV_ROUTES=false
